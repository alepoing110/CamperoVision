<Window x:Class="CamperoDesktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:CamperoDesktop.Helpers"
        Title="Iniciar Sesion"
        Height="720"
        Width="1120"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}">

    <Grid Margin="24">
        <Border CornerRadius="36" Background="#F8FBFF" BorderBrush="#D9E4EF" BorderThickness="1.5">
            <Grid ClipToBounds="True">
                <Ellipse Width="400" Height="400" Fill="#E6F0FB" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-180,-120,0"/>
                <Ellipse Width="280" Height="280" Fill="#F7E6C7" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-90,0,0,-100"/>
                <Ellipse Width="180" Height="180" Fill="#E8F5E8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,40"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="24" Grid.Column="0" CornerRadius="28" Background="{StaticResource SidebarBackgroundBrush}">
                        <Grid Margin="40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <Border Width="62" Height="62" CornerRadius="31" Background="#224A79" HorizontalAlignment="Left">
                                    <TextBlock Text="C" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="CAMPERO" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,20,0,0"/>
                                <TextBlock Text="Sistema de inventario, ventas y control operativo"
                                           Margin="0,10,0,0"
                                           FontSize="16"
                                           Foreground="#BED0E9"
                                           TextWrapping="Wrap"
                                           LineHeight="22"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <Border Width="380"
                                        Height="220"
                                        CornerRadius="28"
                                        Background="White"
                                        Padding="22"
                                        Margin="0,0,0,36">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="28"
                                                          ShadowDepth="6"
                                                          Opacity="0.22"
                                                          Color="Black"/>
                                    </Border.Effect>
                                    <Image Source="Assets/logo.png"
                                           Stretch="Uniform"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                                <TextBlock Text="Accede a productos, clientes, ventas, inventario, compras y reportes con una interfaz mas clara, consistente y preparada para crecer."
                                           Margin="0,20,0,0"
                                           FontSize="15"
                                           Foreground="#D8E6F5"
                                           TextWrapping="Wrap"
                                           LineHeight="22"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" Margin="40,40,44,40">
                        <Border Background="{StaticResource HeroBackgroundBrush}" CornerRadius="30" Padding="42" BorderBrush="#DCE7F2" BorderThickness="1.5" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Bienvenido"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#16202A"/>
                                <TextBlock Text="Ingresa tus credenciales para continuar"
                                           Margin="0,12,0,0"
                                           FontSize="15"
                                           Foreground="#64748B"/>

                                <TextBlock Text="Usuario"
                                           Margin="0,36,0,10"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="#334155"/>
                                <TextBox Height="48"
                                         FontSize="15"
                                         Padding="14,10"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                                <TextBlock Text="Contraseña"
                                           Margin="0,22,0,10"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="#334155"/>
                                <PasswordBox Height="48"
                                             FontSize="15"
                                             Padding="14,10"
                                             helpers:PasswordBoxHelper.BindPassword="True"
                                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Border Background="#FFF4ED" BorderBrush="#F5C9A5" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,20,0,0">
                                    <TextBlock Foreground="#B45309"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Text="{Binding StatusMessage}"/>
                                </Border>

                                <Button Content="Ingresar"
                                        Height="54"
                                        Margin="0,28,0,0"
                                        FontSize="16"
                                        Background="{StaticResource PrimaryBrush}"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Command="{Binding LoginCommand}"/>

                                <Border Background="White" BorderBrush="#E3EAF3" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,22,0,0">
                                    <TextBlock Text="Usa tus credenciales activas para abrir el panel principal y trabajar dentro de una sola ventana."
                                               FontSize="14"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               LineHeight="20"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
