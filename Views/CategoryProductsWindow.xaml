<Window x:Class="CamperoDesktop.Views.CategoryProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos por categoría"
        Height="520"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="TxtTitulo"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="TxtResumen"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Background="{StaticResource PanelBrush}"
                CornerRadius="18"
                Padding="18"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1">
            <DataGrid x:Name="ProductsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdProducto}" Width="70"/>
                    <DataGridTextColumn Header="Cod. barras" Binding="{Binding CodigoBarras}" Width="150"/>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="120"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                    <DataGridTextColumn Header="Compra" Binding="{Binding PrecioCompra, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Venta" Binding="{Binding PrecioVenta, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Stock Min." Binding="{Binding StockMinimo}" Width="95"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="85"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cerrar" Width="100" Height="36" Click="Cerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
