<UserControl x:Class="CamperoDesktop.Views.SalesBetaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,18">
            <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Contable beta"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Vista preliminar para revisar utilidad por producto usando precio de compra y precio vendido del periodo seleccionado."
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,18,0,0">
                        <StackPanel Width="150" Margin="0,0,14,14">
                            <TextBlock Text="Desde" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding FromDate}"/>
                        </StackPanel>

                        <StackPanel Width="150" Margin="0,0,14,14">
                            <TextBlock Text="Hasta" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding ToDate}"/>
                        </StackPanel>

                        <StackPanel Width="240" Margin="0,0,14,14">
                            <TextBlock Text="Almacen" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedItem="{Binding SelectedWarehouse}"
                                      DisplayMemberPath="Nombre"/>
                        </StackPanel>

                        <StackPanel Width="240" Margin="0,0,14,14">
                            <TextBlock Text="Vendedor" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser}"
                                      DisplayMemberPath="Nombre"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,20,0,14">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Hoy"
                                    Width="90"
                                    Command="{Binding TodayCommand}"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Este mes"
                                    Width="100"
                                    Margin="10,0,0,0"
                                    Command="{Binding ThisMonthCommand}"/>
                            <Button Content="Actualizar"
                                    Width="110"
                                    Margin="10,0,0,0"
                                    Command="{Binding RefreshCommand}"/>
                        </StackPanel>
                    </WrapPanel>

                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <WrapPanel Margin="0,18,0,0">
                <Border Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,14,14" Width="220">
                    <StackPanel>
                        <TextBlock Text="Productos con venta" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding ProductsText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,14,14" Width="220">
                    <StackPanel>
                        <TextBlock Text="Ventas del periodo" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding SalesAmountText}" FontSize="24" FontWeight="Bold" Foreground="#166534" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,14,14" Width="220">
                    <StackPanel>
                        <TextBlock Text="Costo del periodo" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding CostAmountText}" FontSize="24" FontWeight="Bold" Foreground="#B45309" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,14,14" Width="220">
                    <StackPanel>
                        <TextBlock Text="Ganancia total" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding ProfitAmountText}" FontSize="24" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,0,14" Width="220">
                    <StackPanel>
                        <TextBlock Text="Margen promedio" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding AverageMarginText}" FontSize="24" FontWeight="Bold" Foreground="#7C3AED" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Ganancia por producto"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left"/>
                        <TextBlock Text="Revision contable beta"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sales}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MinHeight="320">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="110"/>
                            <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="2*"/>
                            <DataGridTextColumn Header="Almacen" Binding="{Binding Almacen}" Width="130"/>
                            <DataGridTextColumn Header="Cant." Binding="{Binding CantidadVendida}" Width="70"/>
                            <DataGridTextColumn Header="P. Venta" Binding="{Binding PrecioVentaPromedio, StringFormat=N2}" Width="95"/>
                            <DataGridTextColumn Header="P. Compra" Binding="{Binding PrecioCompraReferencia, StringFormat=N2}" Width="95"/>
                            <DataGridTextColumn Header="Venta Total" Binding="{Binding TotalVendido, StringFormat=N2}" Width="105"/>
                            <DataGridTextColumn Header="Costo Total" Binding="{Binding CostoTotal, StringFormat=N2}" Width="105"/>
                            <DataGridTextColumn Header="Gan. Unit." Binding="{Binding GananciaUnitaria, StringFormat=N2}" Width="95"/>
                            <DataGridTextColumn Header="Ganancia" Binding="{Binding GananciaTotal, StringFormat=N2}" Width="105"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
