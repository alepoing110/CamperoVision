<UserControl x:Class="CamperoDesktop.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Nombre" Style="{StaticResource FieldLabelStyle}"/>
                <TextBlock Grid.Column="1" Text="Descripcion" Style="{StaticResource FieldLabelStyle}"/>

                <TextBox Grid.Row="1"
                         Margin="0,6,12,0"
                         Height="34"
                         Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,6,12,0"
                         Height="34"
                         Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Nuevo" Width="90" Height="34" Command="{Binding NuevoCommand}"/>
                    <Button Content="Guardar" Width="90" Height="34" Margin="10,0,0,0" Command="{Binding GuardarCommand}"/>
                    <Button Content="Eliminar" Width="90" Height="34" Margin="10,0,0,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding EliminarCommand}"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Margin="0,16,0,0"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10">
                    <TextBlock Text="Las categorias alimentan el modulo de productos. Solo se pueden eliminar si no estan siendo usadas por ningun producto."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="Buscar" VerticalAlignment="Center" Style="{StaticResource FieldLabelStyle}" Margin="0,0,12,0"/>
                        <TextBox Width="280" Height="34" Text="{Binding Buscar, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Buscar" Width="100" Height="34" Margin="12,0,0,0" Command="{Binding BuscarCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Estado}" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Margin="0,18,0,0">
                <DataGrid ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding IdCategoria}" Width="80"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="220"/>
                        <DataGridTextColumn Header="Descripcion" Binding="{Binding Descripcion}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
