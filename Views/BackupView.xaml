<UserControl x:Class="CamperoDesktop.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.InputBindings>
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding CreateBackupCommand}"/>
    </UserControl.InputBindings>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,18">

            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,0,0,8"/>

            <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Backup y Restauracion"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Crea copias de seguridad de la base de datos o restaura desde un backup existente."
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,18,0,0">
                        <StackPanel Width="280" Margin="0,0,16,0">
                            <TextBlock Text="Crear Backup" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="Genera una copia de seguridad completa de la base de datos actual."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <Button Content="Crear Backup Ahora"
                                    Command="{Binding CreateBackupCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Width="280" Margin="0,0,16,0">
                            <TextBlock Text="Restaurar Backup" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="Restaura la base de datos desde el backup mas reciente. Esta accion es irreversible."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <Button Content="Restaurar Ultimo Backup"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding RestoreBackupCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Width="200">
                            <TextBlock Text="Refrescar Lista" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="Actualiza la lista de backups disponibles."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <Button Content="Refrescar"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding RefreshBackupsCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </WrapPanel>

                    <Border Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,18,0,0">
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Backups Disponibles"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Backups}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Padding="8,6"
                                           FontFamily="Consolas"
                                           FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
