<UserControl x:Class="CamperoDesktop.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding GuardarCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NuevoCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding BuscarCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Nombre" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Margin="0,6,12,0" Height="34" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBlock Text="CI/NIT" Grid.Column="1" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,12,0" Height="34" Text="{Binding CiNit, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Telefono" Grid.Column="2" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="2" Margin="0,6,12,0" Height="34" Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Nuevo" Width="90" Height="34" Command="{Binding NuevoCommand}"/>
                    <Button Content="Guardar" Width="90" Height="34" Margin="10,0,0,0" Command="{Binding GuardarCommand}"/>
                </StackPanel>
                <TextBlock Text="Email" Grid.Row="2" Margin="0,14,0,0" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="3" Margin="0,6,12,0" Height="34" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBlock Text="Direccion" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,14,0,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,12,0" Height="34" Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"/>
                <StackPanel Grid.Row="3" Grid.Column="3" Margin="0,6,0,0">
                    <CheckBox Content="Cliente activo" IsChecked="{Binding Activo}"/>
                    <TextBlock Text="{Binding FormStatus}" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="Buscar" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,12,0"/>
                        <TextBox Width="260" Height="34" Text="{Binding Buscar, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Buscar" Width="100" Height="34" Margin="12,0,0,0" Command="{Binding BuscarCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Estado}" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                </DockPanel>
            </Border>
            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Margin="0,18,0,0">
                <DataGrid ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding IdCliente}" Width="70"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                        <DataGridTextColumn Header="CI/NIT" Binding="{Binding CiNit}" Width="140"/>
                        <DataGridTextColumn Header="Telefono" Binding="{Binding Telefono}" Width="130"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                        <DataGridTextColumn Header="Direccion" Binding="{Binding Direccion}" Width="2*"/>
                        <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
