<Window x:Class="CamperoDesktop.Views.LowStockProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos en stock mínimo"
        Height="540"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Productos en stock mínimo"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="TxtResumen"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Background="{StaticResource PanelBrush}"
                CornerRadius="18"
                Padding="18"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1">
            <DataGrid x:Name="ProductsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Almacén" Binding="{Binding Almacen}" Width="180"/>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="130"/>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="2*"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                    <DataGridTextColumn Header="Stock Min." Binding="{Binding StockMinimo}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Imprimir" Width="110" Height="36" Margin="0,0,12,0" Click="Imprimir_Click"/>
            <Button Content="Cerrar" Width="100" Height="36" Click="Cerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
