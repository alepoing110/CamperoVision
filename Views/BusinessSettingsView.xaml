<UserControl x:Class="CamperoDesktop.Views.BusinessSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding ReloadCommand}"/>
    </UserControl.InputBindings>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,18">

            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         Visibility="{Binding SaveCommand.IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Configuracion del negocio"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Aqui definimos los datos institucionales que se usan en reportes, cotizaciones y notas de venta."
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,18,0,0">
                        <StackPanel Width="320" Margin="0,0,14,14">
                            <TextBlock Text="Nombre del negocio" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>

                        <StackPanel Width="250" Margin="0,0,14,14">
                            <TextBlock Text="Telefono" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="250" Margin="0,0,14,14">
                            <TextBlock Text="NIT" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Nit, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="260" Margin="0,0,0,14">
                            <TextBlock Text="Sucursal" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Branch, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel>
                        <StackPanel Width="520" Margin="0,0,14,14">
                            <TextBlock Text="Direccion" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"/>
                        </StackPanel>

                        <StackPanel Width="360" Margin="0,0,14,14">
                            <TextBlock Text="Email" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                            <TextBlock Text="Ruta del logo" Margin="0,14,0,6"/>
                            <TextBox Text="{Binding LogoPath, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Mensaje de pie" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FooterMessage, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="72"/>
                    </StackPanel>

                    <Border Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#475569"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Content="Recargar"
                                Width="110"
                                Command="{Binding ReloadCommand}"/>
                        <Button Content="Guardar configuracion"
                                Width="180"
                                Margin="12,0,0,0"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
