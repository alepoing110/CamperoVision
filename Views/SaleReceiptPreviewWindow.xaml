<Window x:Class="CamperoDesktop.Views.SaleReceiptPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vista previa de nota de venta"
        Height="760"
        Width="1040"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="TxtTitle"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Revisa la nota antes de imprimirla. Si el visor PDF del sistema no carga dentro de la ventana, puedes abrir el archivo externo."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Background="{StaticResource PanelBrush}"
                CornerRadius="18"
                Padding="10"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1">
            <Grid>
                <WebBrowser x:Name="PdfBrowser"/>
                <Border x:Name="FallbackPanel"
                        Background="{StaticResource PanelAltBrush}"
                        CornerRadius="12"
                        Padding="18"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="No se pudo cargar la vista previa embebida del PDF."
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock x:Name="TxtPath"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Content="Abrir PDF"
                    Width="120"
                    Click="AbrirPdf_Click"/>
            <Button Content="Imprimir"
                    Width="120"
                    Margin="12,0,0,0"
                    Click="Imprimir_Click"/>
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Content="Cerrar"
                    Width="100"
                    Margin="12,0,0,0"
                    Click="Cerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
