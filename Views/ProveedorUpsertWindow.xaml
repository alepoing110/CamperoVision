<Window x:Class="CamperoDesktop.Views.ProveedorUpsertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proveedor" Height="500" Width="550" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <StackPanel Margin="0,0,0,20">
                <Label Content="Nombre *" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtNombre" MaxLength="150" Margin="0,0,0,15"/>

                <Label Content="NIT" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtNit" MaxLength="20" Margin="0,0,0,15"/>

                <Label Content="Teléfono" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtTelefono" MaxLength="20" Margin="0,0,0,15"/>

                <Label Content="Email" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtEmail" MaxLength="100" Margin="0,0,0,15"/>

                <Label Content="Dirección" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtDireccion" Height="90" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

                <CheckBox x:Name="ChkActivo" Content="Activo" IsChecked="True" Margin="0,0,0,20"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancelar" Content="Cancelar" Width="90" Height="38" Margin="0,0,12,0" Click="BtnCancelar_Click"/>
            <Button x:Name="BtnGuardar" Content="Guardar" Width="90" Height="38" Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
