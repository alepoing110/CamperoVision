<Window x:Class="CamperoDesktop.Views.SaleNoteEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar nota de venta"
        Height="720"
        Width="1100"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  CanContentScroll="True">
        <Grid Margin="18"
              MinWidth="760">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="#DCE7F2" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding NroNota}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Edicion administrativa de la nota de venta" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}"/>

                    <WrapPanel Margin="0,18,0,0">
                        <StackPanel Width="320" Margin="0,0,14,14">
                            <TextBlock Text="Comprador" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding BuyerName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="200" Margin="0,0,14,14">
                            <TextBlock Text="CI/NIT" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding BuyerCiNit, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="160" Margin="0,0,0,14">
                            <TextBlock Text="Desc. general" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding GeneralDiscount, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0,18,0,0" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="#DCE7F2" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Editor de items"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Aqui puedes buscar otro producto, cambiar una linea existente o agregar una nueva dentro de la misma nota."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,16,0,0">
                        <StackPanel Width="280" Margin="0,0,14,14">
                            <TextBlock Text="Buscar producto" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="320" Margin="0,0,14,14">
                            <TextBlock Text="Producto" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      IsDropDownOpen="{Binding IsProductDropdownOpen}"
                                      DisplayMemberPath="Display"/>
                        </StackPanel>

                        <StackPanel Width="90" Margin="0,0,14,14">
                            <TextBlock Text="Cantidad" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="110" Margin="0,0,14,14">
                            <TextBlock Text="P. unit" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="110" Margin="0,0,14,14">
                            <TextBlock Text="Desc." Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,22,0,14">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="{Binding ItemActionText}"
                                    Width="120"
                                    Command="{Binding AddOrUpdateItemCommand}"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Cancelar"
                                    Width="100"
                                    Margin="10,0,0,0"
                                    Command="{Binding CancelItemEditCommand}"/>
                        </StackPanel>
                    </WrapPanel>

                    <Border Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12">
                        <TextBlock Text="{Binding MatchedProductText}"
                                   Foreground="#475569"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Margin="0,18,0,18" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="#DCE7F2" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="Detalle editable" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" DockPanel.Dock="Left"/>
                        <Button Style="{StaticResource DangerButtonStyle}" Content="Quitar item" Width="110" DockPanel.Dock="Right" Command="{Binding RemoveItemCommand}"/>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding Items}"
                                  SelectedItem="{Binding SelectedItem}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  MinHeight="220"
                                  MaxHeight="360"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" IsReadOnly="True" Width="100"/>
                                <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" IsReadOnly="True" Width="220"/>
                                <DataGridTextColumn Header="Descripcion" Binding="{Binding Descripcion}" IsReadOnly="True" Width="2*"/>
                                <DataGridTextColumn Header="Unidad" Binding="{Binding UnidadMedida}" IsReadOnly="True" Width="90"/>
                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
                                <DataGridTextColumn Header="P. Unit" Binding="{Binding PrecioUnitario, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Desc." Binding="{Binding DescuentoMonto, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" IsReadOnly="True" Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="#DCE7F2" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               Foreground="#475569"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               TextWrapping="Wrap"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cerrar" Width="100" Margin="0,0,12,0" Click="Close_Click"/>
                        <Button Content="Guardar cambios" Width="150" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>

