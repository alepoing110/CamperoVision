<UserControl x:Class="CamperoDesktop.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding GuardarCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NuevoCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding BuscarCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Nombre" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Margin="0,6,12,0" Height="34" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBlock Text="Usuario" Grid.Column="1" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,12,0" Height="34" Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBlock Text="Rol" Grid.Column="2" Foreground="{StaticResource TextBrush}"/>
                <ComboBox Grid.Row="1" Grid.Column="2" Margin="0,6,12,0" Height="34" ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole, ValidatesOnNotifyDataErrors=True}" DisplayMemberPath="Nombre"/>
                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Nuevo" Width="90" Height="34" Command="{Binding NuevoCommand}"/>
                    <Button Content="Guardar" Width="90" Height="34" Margin="10,0,0,0" Command="{Binding GuardarCommand}"/>
                </StackPanel>
                <TextBlock Text="Password" Grid.Row="2" Margin="0,14,0,0" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="3" Margin="0,6,12,0" Height="34" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Margin="0,18,0,0">
            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdUsuario}" Width="70"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                    <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="150"/>
                    <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="120"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="80"/>
                    <DataGridTextColumn Header="Creado" Binding="{Binding CreadoEn}" Width="170"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
