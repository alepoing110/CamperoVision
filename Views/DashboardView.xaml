<UserControl x:Class="CamperoDesktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,20">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Productos" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding TotalProductos}" FontSize="34" FontWeight="Bold" Foreground="#102542" Margin="0,12,0,0"/>
                    <TextBlock Text="Catalogo registrado" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Clientes" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding TotalClientes}" FontSize="34" FontWeight="Bold" Foreground="#0D6E6E" Margin="0,12,0,0"/>
                    <TextBlock Text="Base comercial activa" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Almacenes" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding TotalAlmacenes}" FontSize="34" FontWeight="Bold" Foreground="#8A5A00" Margin="0,12,0,0"/>
                    <TextBlock Text="Puntos de control" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Notas de Venta" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding TotalNotasVenta}" FontSize="34" FontWeight="Bold" Foreground="#7C2D12" Margin="0,12,0,0"/>
                    <TextBlock Text="Operacion comercial" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Ventas hoy" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding VentasHoy, StringFormat=Bs {0:N2}}" FontSize="30" FontWeight="Bold" Foreground="#166534" Margin="0,12,0,0"/>
                    <TextBlock Text="Monto completado del dia" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Ventas del mes" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding VentasMes, StringFormat=Bs {0:N2}}" FontSize="30" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,12,0,0"/>
                    <TextBlock Text="Acumulado mensual completado" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Notas emitidas hoy" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding NotasEmitidasHoy}" FontSize="34" FontWeight="Bold" Foreground="#8A5A00" Margin="0,12,0,0"/>
                    <TextBlock Text="Documentos creados en la fecha" Margin="0,8,0,0" Foreground="#7A8DA4" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Margin="0,0,0,0"
                    Style="{StaticResource CardBorderStyle}"
                    Background="#FFF7ED"
                    BorderBrush="#F5D0A6"
                    BorderThickness="1"
                    Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding ShowLowStockProductsCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="Stock crítico" FontSize="14" Foreground="#B45309"/>
                    <TextBlock Text="{Binding TotalProductosStockMinimo}" FontSize="34" FontWeight="Bold" Foreground="#C2410C" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding LowStockStatus}" Margin="0,8,0,0" Foreground="#9A3412" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,18,0" Background="{StaticResource HeroBackgroundBrush}" Padding="24">
                <StackPanel>
                    <TextBlock Text="Centro de operaciones" FontSize="13" Foreground="#8A5A00" FontWeight="SemiBold"/>
                    <TextBlock Text="Bienvenido al sistema" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding Descripcion}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,10,0,0"/>

                    <UniformGrid Columns="2" Margin="0,24,0,0">
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="16" Padding="18" BorderBrush="#E1EAF4" BorderThickness="1" Margin="0,0,10,10">
                            <StackPanel>
                                <TextBlock Text="Orden recomendado" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="1. Productos y categorias" Margin="0,10,0,0" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="2. Clientes y ventas" Margin="0,6,0,0" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="3. Inventario por almacen" Margin="0,6,0,0" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#102542" CornerRadius="16" Padding="18" Margin="10,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Consejo operativo" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Mantén actualizado el stock y revisa reportes de stock bajo antes de cerrar ventas grandes."
                                           Margin="0,10,0,0"
                                           Foreground="#D6E5F4"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="Sesion actual" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Nombre" Margin="0,20,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding NombreUsuario}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Usuario" Margin="0,16,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Usuario}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Rol" Margin="0,16,0,0" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Rol}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <Border Background="#F7FAFD" CornerRadius="14" Padding="14" Margin="0,24,0,0" BorderBrush="#E1EAF4" BorderThickness="1">
                        <TextBlock Text="Usa el menu lateral para moverte entre modulos sin salir de la ventana principal."
                                   Foreground="#5F7287"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
