<UserControl x:Class="CamperoDesktop.Views.ProvidersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NuevoCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding BuscarCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Nombre" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Margin="0,6,12,0" Height="34" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBlock Text="NIT" Grid.Column="1" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,12,0" Height="34" Text="{Binding Nit, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Teléfono" Grid.Column="2" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="2" Margin="0,6,12,0" Height="34" Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBlock Text="Email" Grid.Column="3" Foreground="{StaticResource TextBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="3" Margin="0,6,12,0" Height="34" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Nuevo" Width="75" Height="34" Command="{Binding NuevoCommand}"/>
                    <Button Content="Guardar" Width="75" Height="34" Margin="5,0,0,0" Command="{Binding GuardarCommand}"/>
                </StackPanel>
                <TextBlock Text="Dirección" Grid.Row="2" Margin="0,14,0,0" Foreground="{StaticResource TextBrush}" Grid.ColumnSpan="2"/>
                <TextBox Grid.Row="3" Margin="0,6,0,0" Height="70" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" Grid.ColumnSpan="4" Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Estado" Grid.Row="4" Margin="0,14,0,0" Foreground="{StaticResource TextBrush}"/>
                <CheckBox Grid.Row="5" Content="Activo" IsChecked="{Binding Activo}"/>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Margin="0,18,0,0">
            <DataGrid ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdProveedor}" Width="70"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="NIT" Binding="{Binding Nit}" Width="120"/>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="Dirección" Binding="{Binding Direccion}" Width="200"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
