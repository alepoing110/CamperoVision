<UserControl x:Class="CamperoDesktop.Views.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveOrderCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NuevaOrdenCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding ReceiveOrderCommand}"/>
    </UserControl.InputBindings>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,18">

            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         Visibility="{Binding SaveOrderCommand.IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,0,0,8"/>

            <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Text="Compras y ordenes de compra"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Nueva orden"
                                    Width="120"
                                    Command="{Binding NuevaOrdenCommand}"/>
                            <Button Content="Recargar"
                                    Width="110"
                                    Margin="12,0,0,0"
                                    Command="{Binding RefreshCommand}"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Text="Registra productos por proveedor, guarda la orden y luego recibela para actualizar inventario."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,18,0,0">
                        <StackPanel Width="260" Margin="0,0,14,14">
                            <TextBlock Text="Proveedor" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Providers}"
                                      SelectedItem="{Binding SelectedProvider}"
                                      DisplayMemberPath="Display"/>
                        </StackPanel>

                        <StackPanel Width="220" Margin="0,0,14,14">
                            <TextBlock Text="Almacen" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedItem="{Binding SelectedWarehouse}"
                                      DisplayMemberPath="Nombre"/>
                        </StackPanel>

                        <StackPanel Width="420" Margin="0,0,14,14">
                            <TextBlock Text="Buscar producto" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding AddItemCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Width="200" Margin="0,0,0,14">
                            <TextBlock Text="Coincidencia" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      IsDropDownOpen="{Binding IsProductDropdownOpen}"
                                      DisplayMemberPath="Display"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel>
                        <StackPanel Width="120" Margin="0,0,14,14">
                            <TextBlock Text="Cantidad" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>

                        <StackPanel Width="140" Margin="0,0,14,14">
                            <TextBlock Text="Costo unitario" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>

                        <StackPanel Width="520" Margin="0,0,14,14">
                            <TextBlock Text="Observaciones" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Observations, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="140" Margin="0,0,0,14">
                            <TextBlock Text="Accion" Margin="0,0,0,6"/>
                            <Button Content="Agregar item"
                                    Command="{Binding AddItemCommand}"/>
                        </StackPanel>
                    </WrapPanel>

                    <Border Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Producto detectado"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding MatchedProductText}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding MatchedProductStatus}"
                                       Foreground="#475569"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Detalle de la orden"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding DraftTotalText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DraftItems}"
                              SelectedItem="{Binding SelectedDraftItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              MinHeight="230">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="120"/>
                            <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="2*"/>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="90"/>
                            <DataGridTextColumn Header="Costo" Binding="{Binding PrecioUnitario, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Style="{StaticResource DangerButtonStyle}" Content="Quitar item"
                                Width="120"
                                Command="{Binding RemoveItemCommand}"/>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Content="Limpiar"
                                Width="110"
                                Margin="12,0,0,0"
                                Command="{Binding NuevaOrdenCommand}"/>
                        <Button Content="Guardar orden"
                                Width="140"
                                Margin="12,0,0,0"
                                Command="{Binding SaveOrderCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,18,0,0" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Ordenes registradas"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MinHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdOrden}" Width="60"/>
                            <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" Width="2*"/>
                            <DataGridTextColumn Header="NIT" Binding="{Binding Nit}" Width="120"/>
                            <DataGridTextColumn Header="Almacen" Binding="{Binding Almacen}" Width="140"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="110"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Recibir orden seleccionada"
                                Width="210"
                                Command="{Binding ReceiveOrderCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

