<Window x:Class="CamperoDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:CamperoDesktop.ViewModels"
        xmlns:views="clr-namespace:CamperoDesktop.Views"
        Title="Sistema Campero"
        Icon="assets/CamperoVisionPro.ico"
        Height="760"
        Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}"><views:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:InventoryViewModel}"><views:InventoryView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WarehousesViewModel}"><views:WarehousesView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProductsViewModel}"><views:ProductsView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:KitsViewModel}"><views:KitsView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoriesViewModel}"><views:CategoriesView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SalesNotesViewModel}"><views:SalesRegisterView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:QuotationViewModel}"><views:QuotationView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SalesBetaViewModel}"><views:SalesBetaView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:BusinessSettingsViewModel}"><views:BusinessSettingsView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ClientsViewModel}"><views:ClientsView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:UsersViewModel}"><views:UsersView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}"><views:ReportsView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProvidersViewModel}"><views:ProvidersView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PurchasesViewModel}"><views:PurchasesView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:BackupViewModel}"><views:BackupView/></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AuditViewModel}"><views:AuditView/></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" Margin="16" CornerRadius="28" Background="#F8FBFF" BorderBrush="#D9E4EF" BorderThickness="1">
            <Grid ClipToBounds="True">
                <Ellipse Width="360" Height="360" Fill="#E5EFFA" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-190,-120,0" Opacity="0.8"/>
                <Ellipse Width="240" Height="240" Fill="#F9E9D1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-100,0,0,-110" Opacity="0.65"/>
            </Grid>
        </Border>

        <Border Grid.Column="0" Margin="26,26,12,26" Background="{StaticResource SidebarBackgroundBrush}" CornerRadius="28">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="28,30,28,18">
                    <Border Width="56" Height="56" CornerRadius="28" Background="#224A79" HorizontalAlignment="Left">
                        <TextBlock Text="C" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="CAMPERO" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,18,0,0"/>
                    <TextBlock Text="Inventario, ventas y control operativo" Foreground="#BCD0E8" FontSize="13" Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20"/>
                    <Border Margin="0,22,0,0" Padding="14,10" CornerRadius="14" Background="#17395F">
                        <TextBlock Text="Accesos rapidos segun tu rol" Foreground="#D8E6F5" FontSize="12" FontWeight="Medium"/>
                    </Border>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                    <StackPanel Margin="18,10,18,14">
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Command="{Binding ShowDashboardCommand}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Productos" Command="{Binding ShowProductosCommand}" Visibility="{Binding ProductosVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Kits" Command="{Binding ShowKitsCommand}" Visibility="{Binding KitsVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Categorias" Command="{Binding ShowCategoriasCommand}" Visibility="{Binding CategoriasVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Clientes" Command="{Binding ShowClientesCommand}" Visibility="{Binding ClientesVisibility}"/>
                        <Border Height="1" Background="#1A3D68" Margin="8,4,8,4"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Notas de Venta" Command="{Binding ShowVentasCommand}" Visibility="{Binding VentasVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Inventario" Command="{Binding ShowInventarioCommand}" Visibility="{Binding InventarioVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Almacenes" Command="{Binding ShowAlmacenesCommand}" Visibility="{Binding AlmacenesVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Cotizaciones" Command="{Binding ShowCotizacionesCommand}" Visibility="{Binding CotizacionesVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Contable Beta" Command="{Binding ShowVentasBetaCommand}" Visibility="{Binding VentasBetaVisibility}"/>
                        <Border Height="1" Background="#1A3D68" Margin="8,4,8,4"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Negocio" Command="{Binding ShowNegocioCommand}" Visibility="{Binding NegocioVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Usuarios" Command="{Binding ShowUsuariosCommand}" Visibility="{Binding UsuariosVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Reportes" Command="{Binding ShowReportesCommand}" Visibility="{Binding ReportesVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Proveedores" Command="{Binding ShowProveedoresCommand}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Compras" Command="{Binding ShowComprasCommand}" Visibility="{Binding ComprasVisibility}"/>
                        <Border Height="1" Background="#1A3D68" Margin="8,4,8,4"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Backup" Command="{Binding ShowBackupCommand}" Visibility="{Binding BackupVisibility}"/>
                        <Button Style="{StaticResource SidebarButtonStyle}" Content="Auditoria" Command="{Binding ShowAuditoriaCommand}" Visibility="{Binding AuditoriaVisibility}"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel DockPanel.Dock="Bottom" Margin="20,14,20,24">
                    <Border Background="#17395F" CornerRadius="18" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Sesion activa" Foreground="#D7E3F4" FontSize="12" FontWeight="Medium"/>
                            <TextBlock Text="{Binding UsuarioActual}" Foreground="White" FontSize="17" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding RolActual}" Foreground="#D4E4F5" FontSize="13" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding EstadoSesion}" Foreground="#F7C97E" FontSize="12" Margin="0,12,0,0" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cerrar Sesion" Margin="0,14,0,0" Command="{Binding CerrarSesionCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="10,26,26,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource HeroBackgroundBrush}" CornerRadius="24" Padding="24" BorderBrush="#DCE7F2" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Panel de control" FontSize="13" Foreground="#8A5A00" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TituloModulo}" FontSize="32" FontWeight="Bold" Foreground="#142032" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding DescripcionModulo}" FontSize="14" Foreground="#5E7086" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Border Background="White" CornerRadius="14" Padding="16,10" BorderBrush="#D8E4F0" BorderThickness="1" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Usuario:" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding UsuarioActual}" FontWeight="SemiBold" Foreground="#16202A" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#102542" CornerRadius="14" Padding="16,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Rol:" Foreground="#C9D9EB" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding RolActual}" FontWeight="SemiBold" Foreground="White" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentContent}" Margin="0,24,0,0"/>
        </Grid>
    </Grid>
</Window>
